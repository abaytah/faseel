# ============================================
# Faseel (فسيل) — Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Database ---
DATABASE_URL="postgresql://faseel:changeme@localhost:5432/faseel"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="generate-a-secure-random-string"
JWT_EXPIRES_IN="7d"

# --- Next.js ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Faseel"

# --- Analytics ---
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# --- File Storage ---
S3_BUCKET=""
S3_REGION="me-south-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- SMS (Unifonic) ---
UNIFONIC_API_KEY=""
UNIFONIC_SENDER_ID="Faseel"

# --- Email ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@faseel.ideaita.me"

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Sentry ---
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
